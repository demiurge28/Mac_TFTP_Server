# macOS
.DS_Store

# Deft installer binary (downloaded, not part of source)
install-macos-universal

# Deft framework core (installed separately, not versioned with project)
.deft/core/

# Deft framework: ignore local-only caches and scratch directories
.deft-cache/
vbrief/.eval/candidates.jsonl
vbrief/.eval/summary-history.jsonl
vbrief/.eval/scope-lifecycle.jsonl
vbrief/.eval/decompositions/
vbrief/.eval/doctor-state.json
vbrief/*.lock
.deft/core.bak-*/
.deft/*.bak-*
*.premigrate.*
